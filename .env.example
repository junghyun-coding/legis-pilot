# 복사해서 .env.local 로 만들고 값을 채우세요 (.env.local 은 git 에 커밋되지 않습니다)
OPENAI_API_KEY=
# 추출용 모델 (입법제안에서 키워드/조문 추출, gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# 분석용 모델 (4축 타당성 검토 멀티콜, 기본 o3)
OPENAI_ANALYZE_MODEL=o3
# 국가법령정보 공유 서비스 인증키 (공공데이터포털 발급, encoding 값)
LAW_API_KEY=
# 국가법령정보 조문 본문 조회용 OC 값 (법령정보 Open API 신청 시 발급된 이메일 아이디)
LAW_OC=
